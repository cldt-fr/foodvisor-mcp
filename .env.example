# Server
PORT=3000
LOG_LEVEL=info

# OAuth
# Public origin where this server is reachable. If unset, derived per-request from
# the Host header + X-Forwarded-Proto. Set this when behind a reverse proxy in prod.
# MCP_PUBLIC_URL=https://foodvisor-mcp.example.com

# HMAC secret used to sign OAuth-issued access tokens. Min 32 chars.
# Generate one with: openssl rand -base64 48
# If unset, a random one is generated at startup (lost on restart, invalidates tokens).
MCP_JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# Lifetime of OAuth-issued access tokens, in seconds. Default 30 days.
# MCP_ACCESS_TOKEN_TTL=2592000
